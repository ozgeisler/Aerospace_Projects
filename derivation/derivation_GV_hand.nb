         RowBox[{"(", 
          RowBox[{"R", "+", "RM", "+", 
           RowBox[{"La", " ", "s"}]}], ")"}]}]}]]}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{
     FractionBox["KT", 
      RowBox[{"s", " ", 
