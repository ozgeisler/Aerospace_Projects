Notebook[{
Cell["Define the matrices of DC Motor", "Text",
 CellChangeTimes->{{3.9803168807601223`*^9, 
  3.9803168950909653`*^9}},ExpressionUUID->"cc899c10-a849-b149-9821-\
e93848bf9774"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"Amat", " ", "=", " ", 
   RowBox[{"(", GridBox[{
      {"0", "1", "0"},
      {"0", 
       RowBox[{
        RowBox[{"-", "c"}], "/", "Jm"}], 
       RowBox[{"KT", "/", "Jm"}]},
      {"0", 
       RowBox[{
        RowBox[{"-", "KV"}], "/", "La"}], 
       RowBox[{
        RowBox[{"-", 
         RowBox[{"(", 
          RowBox[{"RM", "+", "R"}], ")"}]}], "/", "La"}]}
     }], ")"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Bmat", " ", "=", " ", 
   RowBox[{"(", GridBox[{
      {"0", "0"},
      {"0", 
       RowBox[{
        RowBox[{"-", "1"}], "/", "Jm"}]},
      {
       RowBox[{"1", "/", "La"}], "0"}
     }], ")"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Cmat", " ", "=", " ", 
   RowBox[{"(", GridBox[{
      {"0", "1", "0"},
      {"1", "0", "0"},
      {"0", "0", "KT"}
     }], ")"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Dmat", " ", "=", " ", 
   RowBox[{"(", GridBox[{
      {"0", "0"},
      {"0", "0"},
      {"0", "0"}
     }], ")"}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.980316896916708*^9, 3.9803170399605846`*^9}},
 CellLabel->"In[1]:=",ExpressionUUID->"629b0223-9cea-2746-ae44-82cd2d6b1de4"],

Cell[TextData[{
 "To compute the transfer function representation,we can use the equation \
G(s) = C",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    RowBox[{"(", 
     RowBox[{"sI", "-", "A"}], ")"}], 
    RowBox[{"-", "1"}]], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "813c8299-26b4-b146-bde7-f1f6801b3768"],
 "B +D"
}], "Text",
 CellChangeTimes->{{3.980317047345873*^9, 3.9803171089007416`*^9}, {
  3.980317150253399*^9, 
  3.9803171560045223`*^9}},ExpressionUUID->"3bbe5674-3b5e-b84c-8e89-\
229a61653c56"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"G", "[", "s_", "]"}], "=", 
  RowBox[{
   RowBox[{
    RowBox[{"Cmat", ".", 
     RowBox[{"Inverse", "[", 
      RowBox[{
       RowBox[{"s", "*", 
        RowBox[{"IdentityMatrix", "[", "3", "]"}]}], "-", "Amat"}], "]"}], ".",
      "Bmat"}], "+", "Dmat"}], "//", "Simplify"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"G", "[", "s", "]"}], "//", "MatrixForm"}]}], "Input",
 CellChangeTimes->{{3.980317158093611*^9, 3.9803172266740932`*^9}},
 CellLabel->"In[7]:=",ExpressionUUID->"c370d55c-f064-e848-8d98-4fa8f91a9349"],

