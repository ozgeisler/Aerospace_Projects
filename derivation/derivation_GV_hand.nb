            RowBox[{"Jm", " ", "s"}]}], ")"}], " ", 
          RowBox[{"(", 
           RowBox[{"R", "+", "RM", "+", 
            RowBox[{"La", " ", "s"}]}], ")"}]}]}], ")"}]}]], ",", 
     RowBox[{"-", 
