Cell[CellGroupData[{

Cell["\<\
Defining the Position and Velocity of aircraft in response to input force\
\>", "Subsection",
 CellChangeTimes->{{3.9805827703269463`*^9, 3.980582789511381*^9}, {
  3.9805828479467907`*^9, 
  3.980582850810339*^9}},ExpressionUUID->"86993bbf-f57a-9b4b-a044-\
b84b1730aebb"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   SubscriptBox["G", "p"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "665783a2-89d6-8b44-9fe2-9791ee6e2f9d"],
 "(s) = ",
 Cell[BoxData[
  FormBox[
   FractionBox[
    RowBox[{"X", 
     RowBox[{"(", "s", ")"}]}], 
    RowBox[{"U", "(", "s", ")"}]], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "9464c987-6580-d04f-a7b5-c7dbc1e5b0dd"],
 "\n",
 Cell[BoxData[
  FormBox[
   SubscriptBox["G", "v"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "313de1dd-55c5-1146-9dc6-c938475f2b24"],
 "(s) = ",
 Cell[BoxData[
  FormBox[
   FractionBox[
    RowBox[{"V", "(", "s", ")"}], 
    RowBox[{"U", "(", "s", ")"}]], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "9643dfc4-c96a-3f44-92cc-1130db747c4f"],
 "\nm",
 Cell[BoxData[
  FormBox[
   OverscriptBox["x", ".."], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "7e325d0a-b005-ba44-b8e0-651089245097"],
 "(t) = u(t)-",
 Cell[BoxData[
  FormBox[
   SubscriptBox["f", "d"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "0bf023fe-dbd2-c94f-8fd7-939c6bf1233f"],
 "(t)    where  ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["f", "d"], TraditionalForm]],ExpressionUUID->
  "583db0e8-5e8d-a24a-8ae0-3c6fe3c82082"],
 " is the drag force = c",
 Cell[BoxData[
  FormBox[
   OverscriptBox["x", "."], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "de7ef4d5-7e3d-c041-a633-6af5c097cdd1"],
 "(t) (c is 100 N s/m)\nTaking the Laplace Transform of the equation \
(negtecting the ICs due to T.F)\n\n\nX(s) =",
 Cell[BoxData[
  FormBox[
   FractionBox[
    RowBox[{" ", 
     RowBox[{"U", 
      RowBox[{"(", "s", ")"}]}]}], 
    RowBox[{"(", 
     RowBox[{
      SuperscriptBox["ms", "2"], "+", "cs"}], ")"}]], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "8cf343bb-f0dc-a94e-8522-0653a745800d"],
 " and position transfer function is\n                                      ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["G", "p"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "816cc2ca-d734-b34d-9a17-fa50d6850eaf"],
 "(s) = ",
 Cell[BoxData[
  FormBox[
   FractionBox["1", 
    RowBox[{
     SuperscriptBox["ms", "2"], "+", "cs"}]], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "b609288b-6911-e04b-a3fa-2ac760a6ea85"]
}], "Text",
 CellChangeTimes->{{3.980582806931095*^9, 3.9805831648552856`*^9}, {
  3.980583237025013*^9, 
  3.980583237415037*^9}},ExpressionUUID->"9a0942cb-a8ce-234e-b944-\
00018c0220f2"],

Cell[TextData[{
 "For velocity ;\ns*  ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["G", "p"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "0dd54293-55e2-c546-bb7d-b9dc365a0530"],
 "(s) =",
 Cell[BoxData[
  FormBox[
   SubscriptBox["G", "v"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "c1e16915-a1e9-964e-8f0a-40404dd0119d"],
 "(s)  and the velocity transfer function\n                                   \
  ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["G", "v"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "1a72a550-0bf2-aa43-a173-5e04c8484fee"],
 "(s) =",
 Cell[BoxData[
  FormBox[
   FractionBox["1", 
    RowBox[{"ms", "+", "c"}]], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "ad17a30c-b275-cc4f-a7d5-edbbcc6358fd"]
}], "Text",
 CellChangeTimes->{{3.9805830751134243`*^9, 3.9805830854454937`*^9}, {
  3.980583167060375*^9, 
  3.980583226127165*^9}},ExpressionUUID->"0dabd44b-367a-e24c-b05c-\
dcf412aa6bce"],

