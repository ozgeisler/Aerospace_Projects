 RowBox[{
  RowBox[{
   RowBox[{"Gc", "[", "s_", "]"}], "=", " ", 
   FractionBox["5200000", 
    RowBox[{
     SuperscriptBox["s", "2"], "+", 
     RowBox[{"4", " ", "s"}], "+", "13"}]]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Uc", "[", "s_", "]"}], "=", " ", 
   FractionBox["1", "s"]}], ";"}]}], "Input",
 CellChangeTimes->{{3.9805717408649387`*^9, 3.9805718185753536`*^9}},
