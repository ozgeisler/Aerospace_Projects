Cell[CellGroupData[{
Cell["\<\
Define the transfer function  engine thrust and throttle position\
\>", "Subsection",
 CellChangeTimes->{{3.9805715769997463`*^9, 
  3.9805716008741646`*^9}},ExpressionUUID->"4b8615c3-a950-7a4d-8a4d-\
e8922536193f"],

Cell["\<\
Transfer Function force exerted by engines on the aircraft due to the \
throttle position\
\>", "Text",
 CellChangeTimes->{{3.9805716192334137`*^9, 3.9805716547353783`*^9}, {
  3.980581383556637*^9, 
  3.9805813843160324`*^9}},ExpressionUUID->"ea4f5124-8b46-2e41-8de0-\
17e907d536c3"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Ge", "[", "s_", "]"}], "=", 
   FractionBox[
    RowBox[{" ", "500000"}], 
    RowBox[{"s", "+", "2"}]]}], ";"}]], "Input",
 CellChangeTimes->{{3.9805708271767635`*^9, 
  3.9805708995154953`*^9}},ExpressionUUID->"4dd604d6-ed1d-6544-8229-\
46d3691f27fa"],

Cell["\<\
Unit Step  Input response, Transfer Function will allow the output function \
\>", "Text",
 CellChangeTimes->{{3.980570902904663*^9, 3.98057092658111*^9}, {
  3.9805813892261353`*^9, 
  3.980581401178919*^9}},ExpressionUUID->"fdd90f47-b93e-5545-865f-\
bf97a7e14102"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"U", "[", "s_", "]"}], "=", " ", 
   FractionBox["1", "s"]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Fe", "[", "s_", "]"}], "=", " ", 
  RowBox[{
   RowBox[{"Ge", "[", "s", "]"}], "*", 
   RowBox[{"U", "[", "s", "]"}]}]}]}], "Input",
 CellChangeTimes->{{3.9805709319224453`*^9, 3.9805709693118305`*^9}},
 CellLabel->"In[5]:=",ExpressionUUID->"fa5d3f89-e29c-e649-abeb-44d27346a5d0"],

Cell[BoxData[
 FractionBox["500000", 
  RowBox[{"s", " ", 
   RowBox[{"(", 
    RowBox[{"2", "+", "s"}], ")"}]}]]], "Output",
 CellChangeTimes->{3.980570971780945*^9},
 CellLabel->"Out[6]=",ExpressionUUID->"6c92fd68-ba78-fc47-ba27-f9acb95530a2"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"y", "[", "t_", "]"}], "=", " ", 
  RowBox[{"InverseLaplaceTransform", "[", 
   RowBox[{
    RowBox[{"Fe", "[", "s", "]"}], ",", "s", ",", "t"}], "]"}]}]], "Input",
 CellChangeTimes->{{3.9805709740860577`*^9, 3.980570989190586*^9}},
 CellLabel->"In[7]:=",ExpressionUUID->"f096f44a-0a66-3144-8542-6109027a5d12"],

Cell[BoxData[
 RowBox[{"500000", " ", 
  RowBox[{"(", 
   RowBox[{
    FractionBox["1", "2"], "-", 
    FractionBox[
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{
       RowBox[{"-", "2"}], " ", "t"}]], "2"]}], ")"}]}]], "Output",
 CellChangeTimes->{3.9805709897690983`*^9},
 CellLabel->"Out[7]=",ExpressionUUID->"bb1b7f37-91cd-544a-92e9-1688cc4daa67"]
}, Open  ]],

